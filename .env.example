# Stock Agent Configuration
# Copy this file to .env and fill in your values

# === LLM Provider (choose one) ===
# Options: openai, anthropic, openrouter, deepseek
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4.1
LLM_API_KEY=your-key-here
# LLM_BASE_URL=  # optional, for custom endpoints

# === Zerodha Kite Connect ===
KITE_API_KEY=your-kite-api-key
KITE_API_SECRET=your-kite-api-secret
KITE_USER_ID=your-zerodha-user-id
KITE_PASSWORD=your-zerodha-password
KITE_TOTP_SECRET=your-totp-secret

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# === Analysis ===
ANALYSIS_INTERVAL_DAYS=2
RISK_PROFILE=moderate
UNIVERSE=nifty50

# === Paper Trading ===
PAPER_TRADING_CAPITAL=1000000
MAX_POSITION_SIZE_PCT=10
MAX_SECTOR_EXPOSURE_PCT=30
STOP_LOSS_PCT=5
