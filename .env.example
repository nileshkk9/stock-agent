# Stock Agent — Environment Variables
# Copy this to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────
LLM_PROVIDER=opencode
LLM_MODEL=deepseek-v4-pro
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://opencode.ai/zen/go/v1

# ── Broker (pick one) ─────────────────────────────────────────────────
# Options: auto | dhan | kite | local
# auto = try Dhan → Kite → Local in order
PAPER_TRADING_BROKER=auto

# ── Dhan Sandbox (FREE — recommended) ─────────────────────────────────
# Sign up at https://developer.dhanhq.co/ — no Demat, no KYC, no fees
# Or run: python scripts/setup_dhan.py
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ── Zerodha Kite Connect (₹500/mo for data, order APIs free) ──────────
# Sign up at https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=
KITE_ACCESS_TOKEN=

# ── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Paper Trading ─────────────────────────────────────────────────────
PAPER_TRADING_CAPITAL=1000000
MAX_POSITION_SIZE_PCT=10
MAX_SECTOR_EXPOSURE_PCT=30
STOP_LOSS_PCT=5

# ── Analysis ──────────────────────────────────────────────────────────
ANALYSIS_INTERVAL_DAYS=2
RISK_PROFILE=moderate
UNIVERSE=nifty50
