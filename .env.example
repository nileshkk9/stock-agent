# Stock Agent Configuration
# Copy this file to .env and fill in your values
# Lines starting with # are optional

# === REQUIRED: LLM Provider ===
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-chat
LLM_API_KEY=your-api-key-here

# === OPTIONAL: Telegram Daily Reports ===
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# === OPTIONAL: Zerodha Kite (for real NSE data + sandbox) ===
# Get these from https://developers.kite.trade after logging in with Zerodha
# KITE_API_KEY=your-kite-api-key
# KITE_API_SECRET=your-kite-api-secret
# KITE_ACCESS_TOKEN=generated-after-first-login

# === Defaults (change if you want) ===
# ANALYSIS_INTERVAL_DAYS=2
# RISK_PROFILE=moderate
# PAPER_TRADING_CAPITAL=1000000
